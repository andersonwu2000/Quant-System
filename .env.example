# Trading system configuration
QUANT_MODE=backtest                    # backtest | paper | live
QUANT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quant
QUANT_DATA_SOURCE=yahoo                # yahoo | fubon | twse
QUANT_API_HOST=0.0.0.0
QUANT_API_PORT=8000
QUANT_API_KEY=change-me-in-production
# QUANT_API_KEY_ROLES：JSON 格式，設定額外 key→role 映射（不設定則只有 QUANT_API_KEY 有效，對應 admin）
# 合法角色：viewer | researcher | trader | risk_manager | admin
# QUANT_API_KEY_ROLES={"viewer-key-abc": "viewer", "trader-key-xyz": "trader"}
QUANT_LOG_LEVEL=INFO
QUANT_LOG_FORMAT=text                  # text | json
QUANT_MAX_POSITION_PCT=0.05
QUANT_MAX_DAILY_DRAWDOWN_PCT=0.03
QUANT_COMMISSION_RATE=0.001425
QUANT_DEFAULT_SLIPPAGE_BPS=5.0
