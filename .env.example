# ══════════════════════════════════════════════════════════════════
# Quant Trading System — 環境變數配置
#
# 所有變數以 QUANT_ 為前綴，定義於 src/core/config.py (Pydantic Settings)
# 優先級：環境變數 > .env 檔案 > 程式碼預設值
#
# 使用方式：複製此檔案為 .env，依需求取消註解並填入值
#   cp .env.example .env
# ══════════════════════════════════════════════════════════════════

# ── 環境與運行模式 ─────────────────────────────────────────────
QUANT_ENV=dev                          # dev | staging | prod（非 dev 時必須設定 API_KEY 和 JWT_SECRET）
QUANT_MODE=backtest                    # backtest — 離線回測（預設）
                                       # paper    — 紙上交易（需 Shioaji API Key）
                                       # live     — 實盤交易（需 Shioaji API Key + CA 憑證）

# ── 資料庫 ─────────────────────────────────────────────────────
QUANT_DATABASE_URL=sqlite:///data/quant.db
# PostgreSQL 範例：
# QUANT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quant

# ── 數據源 ─────────────────────────────────────────────────────
QUANT_DATA_SOURCE=yahoo                # yahoo   — 全球市場日線（預設）
                                       # finmind — 台股日線 + 財報
                                       # shioaji  — 台股 1 分鐘 K 棒 + tick（需 API Key）
# QUANT_FINMIND_TOKEN=                 # FinMind API token（選填，可提高速率限制）
# QUANT_DATA_CACHE_DIR=.cache/market_data
# QUANT_DATA_CACHE_SIZE=128            # LRU memory cache 最大條目數

# ── 永豐金 Shioaji 券商（paper/live 模式必填）──────────────────
# 申請方式：https://www.sinotrade.com.tw/newweb/PythonAPIKey/
# 1. 登入永豐金個人服務頁面
# 2. 新增 API KEY → 完成 2FA 驗證 → 取得 API Key + Secret Key
# 3. 下載 CA 憑證 (.pfx 檔案)
# QUANT_SINOPAC_API_KEY=your-api-key
# QUANT_SINOPAC_SECRET_KEY=your-secret-key
# QUANT_SINOPAC_CA_PATH=./Sinopac.pfx
# QUANT_SINOPAC_CA_PASSWORD=your-ca-password

# ── API 伺服器 ─────────────────────────────────────────────────
QUANT_API_HOST=127.0.0.1                  # 預設只綁定 localhost（生產環境改 0.0.0.0）
QUANT_API_PORT=8000
# QUANT_API_WORKERS=1                  # Uvicorn worker 數量

# ── 認證與安全 ─────────────────────────────────────────────────
QUANT_API_KEY=dev-key                  # 主 API Key（非 dev 環境必須更換）
QUANT_JWT_SECRET=change-me-in-production  # JWT 簽名密鑰（非 dev 環境必須更換）
# QUANT_ADMIN_PASSWORD=Admin1234       # 首次啟動的管理員密碼
# QUANT_JWT_EXPIRE_MINUTES=1440        # JWT 過期時間（預設 24 小時）
# QUANT_MAX_FAILED_LOGINS=5           # 登入失敗鎖定次數
# QUANT_LOCKOUT_MINUTES=15            # 帳戶鎖定時間（分鐘）
# QUANT_ALLOWED_ORIGINS=["http://localhost:3000"]  # CORS 允許來源（JSON 陣列）

# 額外 API Key → 角色映射（JSON 格式）
# 合法角色：viewer | researcher | trader | risk_manager | admin
# QUANT_API_KEY_ROLES={"viewer-key-abc": "viewer", "trader-key-xyz": "trader"}

# ── 風控參數 ───────────────────────────────────────────────────
QUANT_MAX_POSITION_PCT=0.10            # 單一標的最大權重（10%，配合 15 支等權策略）
# QUANT_MAX_SECTOR_PCT=0.20           # 單一板塊最大權重（20%）
QUANT_MAX_DAILY_DRAWDOWN_PCT=0.03      # 日回撤上限（3%，觸發 kill switch）
# QUANT_KILL_SWITCH_WEEKLY_DRAWDOWN_PCT=0.10  # 週回撤上限（10%）
# QUANT_MAX_DAILY_TRADES=100          # 每日交易次數上限
# QUANT_FAT_FINGER_PCT=0.05           # 肥手指檢查閾值（5%）
# QUANT_MAX_ORDER_VS_ADV_PCT=0.10     # 單筆委託佔日均量上限（10%）

# ── 交易成本 ───────────────────────────────────────────────────
QUANT_COMMISSION_RATE=0.001425         # 手續費率（台灣券商 0.1425%）
# QUANT_TAX_RATE=0.003                # 證交稅（賣出 0.3%）
QUANT_DEFAULT_SLIPPAGE_BPS=5.0         # 預設滑點（basis points）

# ── 市場交易單位 ───────────────────────────────────────────────
# QUANT_FRACTIONAL_SHARES=false        # true = 允許零股交易

# ── 回測參數 ───────────────────────────────────────────────────
# QUANT_BACKTEST_INITIAL_CASH=10000000 # 初始資金（預設 1,000 萬）
# QUANT_BACKTEST_START=2020-01-01
# QUANT_BACKTEST_END=2025-12-31
# QUANT_BACKTEST_TIMEOUT=1800          # 回測超時秒數（預設 30 分鐘）

# ── 通知（擇一設定，留空 = 不通知）──────────────────────────────
# QUANT_NOTIFY_PROVIDER=discord        # discord | line | telegram（留空 = 自動偵測）
# QUANT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
# QUANT_LINE_NOTIFY_TOKEN=your-line-notify-token
# QUANT_TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# QUANT_TELEGRAM_CHAT_ID=123456789

# ── 排程 ───────────────────────────────────────────────────────
# QUANT_SCHEDULER_ENABLED=true         # 啟用 APScheduler
# QUANT_REBALANCE_CRON=0 9 1 * *      # Cron 表達式（預設：每月 1 日 09:00）
# QUANT_REVENUE_SCHEDULER_ENABLED=true # 月營收排程（需 SCHEDULER_ENABLED=true）
# QUANT_REVENUE_UPDATE_CRON=30 8 11 * *    # 每月 11 日 08:30 更新營收數據
# QUANT_REVENUE_REBALANCE_CRON=5 9 11 * *  # 每月 11 日 09:05 營收策略再平衡

# ── Smart Order ──────────────────────────────────────────────
# QUANT_SMART_ORDER_ENABLED=false      # 啟用 TWAP 智能下單
# QUANT_SMART_ORDER_SLICES=5           # TWAP 拆單數量

# ── 日誌 ───────────────────────────────────────────────────────
QUANT_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
QUANT_LOG_FORMAT=text                  # text | json（json 適合 production 日誌收集）
