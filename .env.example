# Trading system configuration
QUANT_MODE=backtest                    # backtest | paper | live
QUANT_DATABASE_URL=sqlite:///data/quant.db    # 或 postgresql://postgres:postgres@localhost:5432/quant
QUANT_DATA_SOURCE=yahoo                # yahoo | finmind | shioaji

# ── 永豐 Shioaji 券商 (paper/live 模式需要) ──
# QUANT_SINOPAC_API_KEY=your-api-key
# QUANT_SINOPAC_SECRET_KEY=your-secret-key
# QUANT_SINOPAC_CA_PATH=./Sinopac.pfx
# QUANT_SINOPAC_CA_PASSWORD=your-ca-password
QUANT_API_HOST=0.0.0.0
QUANT_API_PORT=8000
QUANT_API_KEY=change-me-in-production
# QUANT_API_KEY_ROLES：JSON 格式，設定額外 key→role 映射（不設定則只有 QUANT_API_KEY 有效，對應 admin）
# 合法角色：viewer | researcher | trader | risk_manager | admin
# QUANT_API_KEY_ROLES={"viewer-key-abc": "viewer", "trader-key-xyz": "trader"}
# ── 通知（擇一設定）──
# QUANT_NOTIFY_PROVIDER=discord          # discord | line | telegram（留空=自動偵測）
# QUANT_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
# QUANT_LINE_NOTIFY_TOKEN=your-line-notify-token
# QUANT_TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# QUANT_TELEGRAM_CHAT_ID=123456789
# ── 排程 ──
# QUANT_SCHEDULER_ENABLED=true
# QUANT_REBALANCE_CRON=0 9 1 * *        # 每月1日 09:00

QUANT_LOG_LEVEL=INFO
QUANT_LOG_FORMAT=text                  # text | json
QUANT_MAX_POSITION_PCT=0.05
QUANT_MAX_DAILY_DRAWDOWN_PCT=0.03
QUANT_COMMISSION_RATE=0.001425
QUANT_DEFAULT_SLIPPAGE_BPS=5.0
