FROM node:22-slim

# System tools for agent
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl python3 python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Non-root user
RUN useradd -m -s /bin/bash researcher && \
    mkdir -p /app/work && chown researcher:researcher /app/work && \
    mkdir -p /home/researcher/.claude/session-env && \
    chown -R researcher:researcher /home/researcher/.claude

# Copy research protocol (read-only, agent cannot modify)
COPY scripts/autoresearch/program.md /app/program.md

WORKDIR /app/work
USER researcher

ENV HOME=/home/researcher
ENV CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
ENV CLAUDE_CODE_DISABLE_AUTO_MEMORY=1

# Git safe directory (volume mount ownership mismatch) — must run BEFORE wrapper
RUN git config --global --add safe.directory /app/work

# AP-12: Git wrapper — allowlist (not blocklist) to prevent escape
USER root
RUN mkdir -p /usr/local/lib/git-safe && \
    ln -s /usr/bin/git /usr/local/lib/git-safe/git && \
    printf '#!/bin/sh\n\
CMD="$1"\n\
case "$CMD" in\n\
  add|commit|tag|log|diff|status|show|rev-parse) exec /usr/local/lib/git-safe/git "$@" ;;\n\
  checkout)\n\
    case "$*" in\n\
      *HEAD~1*--*factor.py*) exec /usr/local/lib/git-safe/git "$@" ;;\n\
      *) echo "blocked: only checkout HEAD~1 -- factor.py allowed" >&2; exit 1 ;;\n\
    esac ;;\n\
  *) echo "blocked: git $CMD not in allowlist" >&2; exit 1 ;;\n\
esac\n' > /usr/local/bin/git && \
    chmod +x /usr/local/bin/git
USER researcher
